{
  "schemaVersion": 1,
  "project": {
    "name": "AgentsKit"
  },
  "corpus": {
    "agent": {
      "root": "apps/docs-next/content/docs/for-agents",
      "index": "apps/docs-next/content/docs/for-agents/index.mdx",
      "include": [
        "**/*.md",
        "**/*.mdx"
      ]
    },
    "human": {
      "plugin": "fumadocs",
      "options": {
        "contentDir": "apps/docs-next/content/docs",
        "urlPrefix": "/docs"
      }
    }
  },
  "routing": {
    "plugin": "pnpm-monorepo",
    "options": {
      "packages": [
        "packages/*"
      ]
    }
  },
  "index": {
    "outFile": ".doc-bridge/index.json",
    "llmsTxt": {
      "enabled": true,
      "outFile": "llms.txt",
      "preamble": "AgentsKit is a plug-and-play TypeScript toolkit for building production agents: adapters, runtime, tools, skills, memory, RAG, UI, observability, sandboxing, evals, and templates."
    },
    "capabilities": {
      "enabled": true,
      "outFile": ".doc-bridge/capabilities.json"
    }
  },
  "gates": {
    "preset": "standard",
    "include": [
      "documentation-standard-v1"
    ]
  },
  "conformance": {
    "documentationStandardV1": {
      "rawSources": [
        "README.md",
        "apps/docs-next/content/docs/get-started/getting-started/build-your-first-agent.mdx",
        "apps/docs-next/content/docs/for-agents/index.mdx"
      ],
      "contributionPaths": [
        "CONTRIBUTING.md"
      ],
      "metadata": [
        {
          "path": "apps/docs-next/app/layout.tsx",
          "contains": [
            "export const metadata",
            "title:",
            "description:",
            "openGraph:",
            "twitter:"
          ]
        }
      ],
      "links": [
        {
          "url": "https://registry.agentskit.io/docs",
          "paths": [
            "apps/docs-next/content/docs/get-started/getting-started/build-your-first-agent.mdx"
          ]
        },
        {
          "url": "https://chat.agentskit.io/docs",
          "paths": [
            "apps/docs-next/content/docs/get-started/getting-started/build-your-first-agent.mdx"
          ]
        },
        {
          "url": "https://playbook.agentskit.io/docs",
          "paths": [
            "apps/docs-next/content/docs/get-started/getting-started/build-your-first-agent.mdx"
          ]
        },
        {
          "url": "https://agentskit-io.github.io/doc-bridge/",
          "paths": [
            "apps/docs-next/content/docs/get-started/getting-started/build-your-first-agent.mdx"
          ]
        },
        {
          "url": "https://github.com/AgentsKit-io/code-review-cli#readme",
          "paths": [
            "apps/docs-next/content/docs/get-started/getting-started/build-your-first-agent.mdx"
          ]
        },
        {
          "url": "https://akos.agentskit.io/docs",
          "paths": [
            "apps/docs-next/content/docs/get-started/getting-started/build-your-first-agent.mdx"
          ]
        }
      ],
      "ecosystemContract": {
        "manifest": "ecosystem.json",
        "claims": "ecosystem-claims.json",
        "productId": "agentskit"
      },
      "quickstarts": [
        {
          "id": "first-agent",
          "doc": "apps/docs-next/content/docs/get-started/getting-started/build-your-first-agent.mdx",
          "test": "scripts/reference-docs-vertical.test.mjs",
          "command": "pnpm test:reference-docs",
          "testContains": [
            "the first-agent fixture runs without credentials or network access",
            "fixtures/first-agent/agent.ts"
          ]
        }
      ],
      "visuals": [
        "apps/docs-next/public/demos/install.gif",
        "apps/docs-next/public/demos/chat-streaming.gif",
        "apps/docs-next/public/brand/og-default.png"
      ],
      "diagrams": [
        {
          "path": "apps/docs-next/content/docs/get-started/getting-started/build-your-first-agent.mdx",
          "contains": [
            "```mermaid"
          ]
        }
      ]
    }
  },
  "surfaces": {
    "cli": {
      "bin": "ak-docs",
      "defaultFormat": "text"
    },
    "mcp": {
      "enabled": true,
      "transport": "stdio"
    }
  }
}
