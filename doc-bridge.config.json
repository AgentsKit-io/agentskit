{
  "schemaVersion": 1,
  "project": { "name": "agentskit" },
  "corpus": {
    "agent": {
      "root": "apps/docs-next/content/docs/for-agents",
      "index": "apps/docs-next/content/docs/for-agents/index.mdx",
      "include": ["**/*.{md,mdx}"],
      "exclude": ["**/meta.json", "**/node_modules/**"]
    },
    "human": {
      "plugin": "fumadocs",
      "options": {
        "contentDir": "apps/docs-next/content/docs",
        "urlPrefix": "/docs",
        "metaFile": "meta.json"
      }
    }
  },
  "routing": {
    "plugin": "pnpm-monorepo",
    "options": {
      "packages": ["packages/*"]
    }
  },
  "index": {
    "outFile": ".doc-bridge/index.json",
    "llmsTxt": { "enabled": true, "outFile": ".doc-bridge/llms.txt" },
    "capabilities": { "enabled": true, "outFile": ".doc-bridge/capabilities.json" }
  },
  "gates": {
    "preset": "standard",
    "exclude": ["okf-type"]
  },
  "surfaces": {
    "cli": { "bin": "ak-docs", "defaultFormat": "json" },
    "mcp": {
      "enabled": true,
      "tools": ["handoff.resolve", "doc.search", "doc.get", "gate.status"]
    }
  },
  "federation": {
    "enabled": true,
    "sources": [
      {
        "id": "playbook",
        "llmsTxt": "https://playbook.agentskit.io/llms.txt",
        "rawBaseUrl": "https://playbook.agentskit.io/raw/"
      },
      {
        "id": "registry",
        "llmsTxt": "https://registry.agentskit.io/llms.txt"
      }
    ]
  }
}
