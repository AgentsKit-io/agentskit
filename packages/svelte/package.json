{
  "name": "@agentskit/svelte",
  "version": "0.3.1",
  "description": "Svelte 5 store + headless chat components for AgentsKit — streaming, tools, and memory across any LLM provider.",
  "keywords": [
    "agentskit",
    "ai",
    "agents",
    "llm",
    "chat",
    "typescript",
    "svelte",
    "store",
    "headless",
    "openai",
    "anthropic",
    "claude",
    "gemini",
    "chatgpt",
    "ai-agents",
    "chat-ui",
    "streaming",
    "svelte5",
    "ui"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "dev": "tsup --watch"
  },
  "dependencies": {
    "@agentskit/core": "workspace:*"
  },
  "peerDependencies": {
    "svelte": "^5.0.0"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.3.1",
    "@types/node": "^25.9.3",
    "esbuild-svelte": "^0.9.5",
    "svelte": "^5.56.3",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "publishConfig": {
    "access": "public"
  },
  "agentskit": {
    "stability": "beta",
    "stabilityNote": "createChatStore (ChatReturn contract) + full headless component parity with @agentskit/react (Svelte 5 runes)."
  },
  "license": "MIT",
  "homepage": "https://www.agentskit.io/docs/packages/svelte",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AgentsKit-io/agentskit.git",
    "directory": "packages/svelte"
  },
  "bugs": {
    "url": "https://github.com/AgentsKit-io/agentskit/issues"
  },
  "author": "AgentsKit Contributors"
}
