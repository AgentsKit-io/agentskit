{
  "name": "@agentskit/cli",
  "version": "0.13.11",
  "description": "CLI for AgentsKit chat and project scaffolding.",
  "keywords": [
    "agentskit",
    "ai",
    "agents",
    "llm",
    "chat",
    "typescript",
    "cli",
    "command-line",
    "scaffolding",
    "openai",
    "anthropic",
    "claude",
    "gemini",
    "chatgpt",
    "ai-agents",
    "autonomous-agents",
    "create-app",
    "terminal"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "agentskit": "./dist/bin.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "dev": "tsup --watch"
  },
  "dependencies": {
    "@agentskit/adapters": "workspace:*",
    "@agentskit/core": "workspace:*",
    "@agentskit/ink": "workspace:*",
    "@agentskit/integrations": "workspace:*",
    "@agentskit/memory": "workspace:*",
    "@agentskit/rag": "workspace:*",
    "@agentskit/runtime": "workspace:*",
    "@agentskit/skills": "workspace:*",
    "@agentskit/tools": "workspace:*",
    "@inquirer/prompts": "^8.5.2",
    "chokidar": "^5.0.0",
    "commander": "^14.0.3",
    "ink": "^7.1.0",
    "kleur": "^4.1.5",
    "localtunnel": "^2.0.2",
    "react": "^19.2.7",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/localtunnel": "^2.0.4",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "happy-dom": "^20.10.3",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "publishConfig": {
    "access": "public"
  },
  "agentskit": {
    "stability": "beta",
    "stabilityNote": "chat, init, run commands stable."
  },
  "license": "MIT",
  "homepage": "https://www.agentskit.io/docs/packages/cli",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AgentsKit-io/agentskit.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/AgentsKit-io/agentskit/issues"
  },
  "author": "AgentsKit Contributors"
}
