{
  "name": "@agentskit/vue",
  "version": "0.3.0",
  "description": "Vue 3 composable + headless chat components for AgentsKit — streaming, tools, and memory across any LLM provider.",
  "keywords": [
    "agentskit",
    "ai",
    "agents",
    "llm",
    "chat",
    "typescript",
    "vue",
    "vue3",
    "composable",
    "headless",
    "openai",
    "anthropic",
    "claude",
    "gemini",
    "chatgpt",
    "ai-agents",
    "chat-ui",
    "streaming",
    "composition-api",
    "ui"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "dev": "tsup --watch"
  },
  "dependencies": {
    "@agentskit/core": "workspace:*"
  },
  "peerDependencies": {
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "happy-dom": "^20.10.3",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9",
    "vue": "^3.5.38"
  },
  "publishConfig": {
    "access": "public"
  },
  "agentskit": {
    "stability": "beta",
    "stabilityNote": "useChat (ChatReturn contract) + full headless component parity with @agentskit/react; 100% component coverage."
  },
  "license": "MIT",
  "homepage": "https://www.agentskit.io/docs/packages/vue",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AgentsKit-io/agentskit.git",
    "directory": "packages/vue"
  },
  "bugs": {
    "url": "https://github.com/AgentsKit-io/agentskit/issues"
  },
  "author": "AgentsKit Contributors"
}
