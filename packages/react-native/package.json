{
  "name": "@agentskit/react-native",
  "version": "0.3.2",
  "description": "React Native + Expo hook and headless chat components for AgentsKit — streaming, tools, and memory across any LLM provider.",
  "keywords": [
    "agentskit",
    "ai",
    "agents",
    "llm",
    "chat",
    "typescript",
    "react-native",
    "expo",
    "mobile",
    "hooks",
    "openai",
    "anthropic",
    "claude",
    "gemini",
    "chatgpt",
    "ai-agents",
    "chat-ui",
    "streaming",
    "ios",
    "android"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "dev": "tsup --watch"
  },
  "dependencies": {
    "@agentskit/core": "workspace:*"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-native": "*"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "happy-dom": "^20.10.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  },
  "publishConfig": {
    "access": "public"
  },
  "agentskit": {
    "stability": "beta",
    "stabilityNote": "React Native / Expo binding — full headless component parity with @agentskit/react (8 components), rendered with RN primitives and a testID-based headless convention."
  },
  "license": "MIT",
  "homepage": "https://www.agentskit.io/docs/packages/react-native",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AgentsKit-io/agentskit.git",
    "directory": "packages/react-native"
  },
  "bugs": {
    "url": "https://github.com/AgentsKit-io/agentskit/issues"
  },
  "author": "AgentsKit Contributors"
}
