{
  "name": "@agentskit/core",
  "version": "1.12.0",
  "description": "Portable AgentsKit runtime for chat orchestration, tools, memory, and retrieval.",
  "keywords": [
    "agentskit",
    "ai",
    "agents",
    "llm",
    "chat",
    "typescript",
    "orchestration",
    "streaming",
    "tools",
    "openai",
    "anthropic",
    "claude",
    "gemini",
    "chatgpt",
    "ai-agents",
    "autonomous-agents",
    "zero-dependencies",
    "edge-runtime"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./agent-schema": {
      "types": "./dist/agent-schema.d.ts",
      "import": "./dist/agent-schema.js",
      "require": "./dist/agent-schema.cjs"
    },
    "./prompt-experiments": {
      "types": "./dist/prompt-experiments.d.ts",
      "import": "./dist/prompt-experiments.js",
      "require": "./dist/prompt-experiments.cjs"
    },
    "./auto-summarize": {
      "types": "./dist/auto-summarize.d.ts",
      "import": "./dist/auto-summarize.js",
      "require": "./dist/auto-summarize.cjs"
    },
    "./hitl": {
      "types": "./dist/hitl.d.ts",
      "import": "./dist/hitl.js",
      "require": "./dist/hitl.cjs"
    },
    "./security": {
      "types": "./dist/security.d.ts",
      "import": "./dist/security.js",
      "require": "./dist/security.cjs"
    },
    "./fuzzy-match": {
      "types": "./dist/fuzzy-match.d.ts",
      "import": "./dist/fuzzy-match.js",
      "require": "./dist/fuzzy-match.cjs"
    },
    "./finding": {
      "types": "./dist/finding.d.ts",
      "import": "./dist/finding.js",
      "require": "./dist/finding.cjs"
    },
    "./compose-tool": {
      "types": "./dist/compose-tool.d.ts",
      "import": "./dist/compose-tool.js",
      "require": "./dist/compose-tool.cjs"
    },
    "./self-debug": {
      "types": "./dist/self-debug.d.ts",
      "import": "./dist/self-debug.js",
      "require": "./dist/self-debug.cjs"
    },
    "./generative-ui": {
      "types": "./dist/generative-ui.d.ts",
      "import": "./dist/generative-ui.js",
      "require": "./dist/generative-ui.cjs"
    },
    "./a2a": {
      "types": "./dist/a2a.d.ts",
      "import": "./dist/a2a.js",
      "require": "./dist/a2a.cjs"
    },
    "./manifest": {
      "types": "./dist/manifest.d.ts",
      "import": "./dist/manifest.js",
      "require": "./dist/manifest.cjs"
    },
    "./eval-format": {
      "types": "./dist/eval-format.d.ts",
      "import": "./dist/eval-format.js",
      "require": "./dist/eval-format.cjs"
    },
    "./memory-validation": {
      "types": "./dist/memory-validation.d.ts",
      "import": "./dist/memory-validation.js",
      "require": "./dist/memory-validation.cjs"
    },
    "./tool-proposal": {
      "types": "./dist/tool-proposal.d.ts",
      "import": "./dist/tool-proposal.js",
      "require": "./dist/tool-proposal.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "dev": "tsup --watch"
  },
  "devDependencies": {
    "@types/json-schema": "^7.0.15",
    "@types/node": "^25.9.5",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  },
  "publishConfig": {
    "access": "public"
  },
  "agentskit": {
    "stability": "stable",
    "stabilityNote": "Sacred package. Contract-stable per ADRs 0001-0006."
  },
  "license": "MIT",
  "homepage": "https://www.agentskit.io/docs/packages/core",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AgentsKit-io/agentskit.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/AgentsKit-io/agentskit/issues"
  },
  "author": "AgentsKit Contributors"
}
