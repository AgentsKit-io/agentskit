{
  "name": "@agentskit/ink",
  "version": "0.9.2",
  "description": "Ink terminal components and hooks for AgentsKit.",
  "keywords": [
    "agentskit",
    "ai",
    "agents",
    "llm",
    "chat",
    "typescript",
    "ink",
    "terminal",
    "cli",
    "openai",
    "anthropic",
    "claude",
    "gemini",
    "chatgpt",
    "ai-agents",
    "tui",
    "chat-ui",
    "streaming"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "dev": "tsup --watch"
  },
  "dependencies": {
    "@agentskit/core": "workspace:*",
    "ink": "^7.1.0",
    "marked": "^18.0.6",
    "marked-terminal": "^7.3.0"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "@types/marked-terminal": "^6.1.1",
    "@types/node": "^25.9.5",
    "@types/react": "^19.2.17",
    "ink-testing-library": "^4.0.0",
    "react": "^19.2.7",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  },
  "publishConfig": {
    "access": "public"
  },
  "agentskit": {
    "stability": "beta",
    "stabilityNote": "Terminal UI at parity with @agentskit/react."
  },
  "license": "MIT",
  "homepage": "https://www.agentskit.io/docs/packages/ink",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AgentsKit-io/agentskit.git",
    "directory": "packages/ink"
  },
  "bugs": {
    "url": "https://github.com/AgentsKit-io/agentskit/issues"
  },
  "author": "AgentsKit Contributors"
}
