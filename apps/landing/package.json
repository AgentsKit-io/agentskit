{
  "name": "@agentskit/landing",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "prebuild": "node ../../scripts/gen-ecosystem-stats.mjs && node ../../scripts/sync-ecosystem.mjs && node ../../scripts/sync-brand.mjs --property agentskit --format landing --out apps/landing/app/globals.css",
    "gen:stats": "node ../../scripts/gen-ecosystem-stats.mjs",
    "dev": "next dev --turbo --port 4180",
    "build": "next build",
    "start": "next start --port 4180",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "next": "^16.2.9",
    "posthog-js": "^1.386.8",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.1",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3"
  }
}
