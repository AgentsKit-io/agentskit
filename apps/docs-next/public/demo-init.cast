[0.528, "o", "\r\n\u001b[1m\u001b[32m▲\u001b[22m\u001b[39m \u001b[1magentskit init\u001b[22m\r\n"]
[0.000, "o", "\u001b[2m   Generate a starter project — answer five questions.\r\n\r\n\u001b[22m"]
[0.003, "o", "\u001b[34m?\u001b[39m \u001b[1mProject directory:\u001b[22m \u001b[2m(agentskit-app)\u001b[22m\u001b[38G"]
[6.361, "o", "\u001b[2K\u001b[G\u001b[34m?\u001b[39m \u001b[1mProject directory:\u001b[22m \u001b[2m(agentskit-app)\u001b[22m\u001b[38G"]
[0.000, "o", "\u001b[2K\u001b[G\u001b[34m?\u001b[39m \u001b[1mProject directory:\u001b[22m agentskit-app\u001b[35G"]
[0.003, "o", "\u001b[2K\u001b[G\u001b[32m✔\u001b[39m \u001b[1mProject directory:\u001b[22m \u001b[36magentskit-app\u001b[39m\u001b[35G"]
[0.001, "o", "\r\n\u001b[?25h"]
[0.003, "o", "\u001b[34m?\u001b[39m \u001b[1mTemplate:\u001b[22m\r\n\u001b[36m❯ React chat (Vite + browser)\u001b[39m\r\n  Ink chat (terminal UI)\r\n  Runtime (headless agent, no UI)\r\n  Multi-agent (planner + delegates)\r\n\r\n\u001b[36mStreaming UI with @agentskit/react\u001b[39m\r\n\u001b[1m↑↓\u001b[22m \u001b[2mnavigate\u001b[22m\u001b[2m • \u001b[22m\u001b[1m⏎\u001b[22m \u001b[2mselect\u001b[22m\u001b[?25l\u001b[23G"]
[4.058, "o", "\u001b[2K\u001b[1A\u001b[2K\u001b[1A\u001b[2K\u001b[1A\u001b[2K\u001b[1A\u001b[2K\u001b[1A\u001b[2K\u001b[1A\u001b[2K\u001b[1A\u001b[2K\u001b[G\u001b[34m?\u001b[39m \u001b[1mTemplate:\u001b[22m\r\n  React chat (Vite + browser)\r\n\u001b[36m❯ Ink chat (terminal UI)\u001b[39m\r\n  Runtime (headless agent, no UI)\r\n  Multi-agent (planner + delegates)\r\n\r\n\u001b[36mSame chat but in your terminal\u001b[39m\r\n\u001b[1m↑↓\u001b[22m \u001b[2mnavigate\u001b[22m\u001b[2m • \u001b[22m\u001b[1m⏎\u001b[22m \u001b[2mselect\u001b[22m\u001b[?25l\u001b[23G"]
[0.678, "o", "\u001b[2K\u001b[1A\u001b[2K\u001b[1A\u001b[2K\u001b[1A\u001b[2K\u001b[1A\u001b[2K\u001b[1A\u001b[2K\u001b[1A\u001b[2K\u001b[1A\u001b[2K\u001b[G\u001b[34m?\u001b[39m \u001b[1mTemplate:\u001b[22m\r\n  React chat (Vite + browser)\r\n  Ink chat (terminal UI)\r\n\u001b[36m❯ Runtime (headless agent, no UI)\u001b[39m\r\n  Multi-agent (planner + delegates)\r\n\r\n\u001b[36mAutonomous task → result\u001b[39m\r\n\u001b[1m↑↓\u001b[22m \u001b[2mnavigate\u001b[22m\u001b[2m • \u001b[22m\u001b[1m⏎\u001b[22m \u001b[2mselect\u001b[22m\u001b[?25l\u001b[23G"]
[0.507, "o", "\u001b[2K\u001b[1A\u001b[2K\u001b[1A\u001b[2K\u001b[1A\u001b[2K\u001b[1A\u001b[2K\u001b[1A\u001b[2K\u001b[1A\u001b[2K\u001b[1A\u001b[2K\u001b[G\u001b[34m?\u001b[39m \u001b[1mTemplate:\u001b[22m\r\n  React chat (Vite + browser)\r\n  Ink chat (terminal UI)\r\n  Runtime (headless agent, no UI)\r\n\u001b[36m❯ Multi-agent (planner + delegates)\u001b[39m\r\n\r\n\u001b[36mSupervisor pattern, ready to extend\u001b[39m\r\n\u001b[1m↑↓\u001b[22m \u001b[2mnavigate\u001b[22m\u001b[2m • \u001b[22m\u001b[1m⏎\u001b[22m \u001b[2mselect\u001b[22m\u001b[?25l\u001b[23G"]
[1.647, "o", "\u001b[2K\u001b[1A\u001b[2K\u001b[1A\u001b[2K\u001b[1A\u001b[2K\u001b[1A\u001b[2K\u001b[1A\u001b[2K\u001b[1A\u001b[2K\u001b[1A\u001b[2K\u001b[G\u001b[34m?\u001b[39m \u001b[1mTemplate:\u001b[22m\r\n\u001b[36m❯ React chat (Vite + browser)\u001b[39m\r\n  Ink chat (terminal UI)\r\n  Runtime (headless agent, no UI)\r\n  Multi-agent (planner + delegates)\r\n\r\n\u001b[36mStreaming UI with @agentskit/react\u001b[39m\r\n\u001b[1m↑↓\u001b[22m \u001b[2mnavigate\u001b[22m\u001b[2m • \u001b[22m\u001b[1m⏎\u001b[22m \u001b[2mselect\u001b[22m\u001b[?25l\u001b[23G"]
