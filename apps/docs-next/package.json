{
  "name": "@agentskit/docs-next",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "prebuild": "node scripts/build-dependencies.mjs && node scripts/gen-api.mjs && node scripts/gen-changelog.mjs && node scripts/gen-performance.mjs && node scripts/gen-ask-context.mjs && node ../../scripts/gen-ecosystem-stats.mjs && node ../../scripts/gen-ecosystem-claims.mjs && node ../../scripts/sync-ecosystem.mjs && node ../../scripts/sync-brand.mjs --property agentskit --out apps/docs-next/app/brand-tokens.css && node scripts/gen-deterministic-knowledge.mjs",
    "gen:stats": "node ../../scripts/gen-ecosystem-stats.mjs",
    "gen:claims": "node ../../scripts/gen-ecosystem-claims.mjs",
    "gen:ask-context": "node scripts/gen-ask-context.mjs",
    "gen:deterministic-knowledge": "node scripts/gen-deterministic-knowledge.mjs",
    "gen:changelog": "node scripts/gen-changelog.mjs",
    "gen:performance": "node scripts/gen-performance.mjs",
    "measure:sizes": "node scripts/measure-sizes.mjs",
    "docs:new": "node scripts/docs-new.mjs",
    "build": "next build",
    "dev": "next dev --turbo",
    "docs": "next dev --turbo",
    "start": "next start",
    "lint": "node scripts/gen-ask-context.mjs && tsc --noEmit",
    "lint:mdx": "node scripts/lint-mdx.mjs",
    "check:links": "node scripts/check-links.mjs",
    "gen:api": "node scripts/gen-api.mjs",
    "postinstall": "fumadocs-mdx",
    "gen:ask-index": "tsx scripts/gen-ask-index.mjs",
    "eval:ask-docs": "tsx lib/ask/eval/run.ts"
  },
  "dependencies": {
    "@agentskit/adapters": "workspace:*",
    "@agentskit/chat": "0.4.0",
    "@agentskit/core": "workspace:*",
    "@agentskit/eval": "workspace:*",
    "@agentskit/memory": "workspace:*",
    "@agentskit/observability": "workspace:*",
    "@agentskit/rag": "workspace:*",
    "@agentskit/react": "workspace:*",
    "@agentskit/runtime": "workspace:*",
    "@agentskit/sandbox": "workspace:*",
    "@agentskit/skills": "workspace:*",
    "@agentskit/tools": "workspace:*",
    "@codesandbox/sandpack-react": "^2.20.0",
    "@huggingface/transformers": "^4.2.0",
    "@tailwindcss/postcss": "^4.3.2",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "fumadocs-core": "^16.11.1",
    "fumadocs-mdx": "^15.1.0",
    "fumadocs-ui": "^16.11.1",
    "mermaid": "^11.16.0",
    "motion": "^12.42.2",
    "next": "^16.2.10",
    "postcss": "^8.5.16",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "redis": "^6.1.0",
    "remark-gfm": "^4.0.1",
    "shiki": "^4.3.1",
    "tailwindcss": "^4.3.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/mdx": "^2.0.14",
    "@types/node": "^25.9.5",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "tsx": "^4.23.0",
    "typedoc": "^0.28.20",
    "typedoc-plugin-markdown": "^4.12.0",
    "typescript": "^7.0.2"
  }
}
